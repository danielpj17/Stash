# Google Apps Script Web App URL (e.g. after deploying as web app, deploy > Test deployments or Exec URL)
# Sheet columns: Timestamp, Expense Type, Amount, Description, Month
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyR8nt4CQd90TgHKhk09TN_RUTxDcVg2rpAl9JF1MWgRp0hIYP9SAkcZJjhSA9X5maunQ/exec

# Neon Postgres connection string (for budget sync across devices). Get from Neon dashboard after creating a project.
DATABASE_URL=

# SnapTrade (server-side only). Used by /api/snaptrade/refresh-balances when the Budget page
# Account Balances header refresh button is clicked.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=
